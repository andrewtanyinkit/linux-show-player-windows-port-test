# Modules to exclude — Linux-only or unavailable on Windows
excludes = [
    "pyalsa",
    "alsaseq",
    "jack",
    "pyliblo3",
    "liblo",
    "ola",
    # gi is provided by gi_stub at analysis time; exclude real GStreamer libs
    # but NOT gi itself — the stub lets PyInstaller trace code that imports gi.
    "lisp.plugins.gst_backend",
    "lisp.plugins.replay_gain",
    "lisp.plugins.timecode.protocols.artnet",
    "tkinter",
    "matplotlib",
    "scipy",
    "PIL",
    "test",
    "unittest",
    "xmlrpc",
    # NOTE: do NOT exclude 'distutils' — PyInstaller has its own hook that
    # aliases it; excluding it causes a ValueError during analysis.
]

a = Analysis(
    [str(ROOT / "lisp" / "main.py")],
    pathex=[str(ROOT)],
    binaries=[],
    datas=datas,
    hiddenimports=hidden_imports,
    hookspath=[],
    hooksconfig={},
    runtime_hooks=[str(ROOT / "windows_runtime_hook.py")],
    excludes=excludes,
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
    noarchive=False,
)

pyz = PYZ(a.pure, a.zipped_data, cipher=block_cipher)

exe = EXE(
    pyz,
    a.scripts,
    a.binaries,
    a.zipfiles,
    a.datas,
    [],
    name="LinuxShowPlayer",
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    upx_exclude=[],
    runtime_tmpdir=None,
    console=False,
    disable_windowed_traceback=False,
    argv_emulation=False,
