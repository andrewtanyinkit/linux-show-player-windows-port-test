# -*- mode: python ; coding: utf-8 -*-
#
# PyInstaller spec file for Linux Show Player (Windows portable build)
#
# To build on Windows:
#   pip install -r requirements-windows.txt
#   pyinstaller build_windows.spec --noconfirm --clean
#
# The output is dist/LinuxShowPlayer.exe  (single portable executable)

import os
from pathlib import Path

block_cipher = None
ROOT = Path(SPECPATH)


def collect_data(src_rel, dest_rel):
    """Return a datas tuple only if the source path exists."""
    src = ROOT / src_rel
    if src.exists():
        return (str(src), dest_rel)
    return None


# All data files that must be bundled inside the executable
_datas_raw = [
    # Core config
    collect_data("lisp/default.json", "lisp"),

    # UI themes (dark & light, including image assets)
    collect_data("lisp/ui/themes/dark",  "lisp/ui/themes/dark"),
    collect_data("lisp/ui/themes/light", "lisp/ui/themes/light"),

    # Icon themes
    collect_data("lisp/ui/icons/lisp",  "lisp/ui/icons/lisp"),
    collect_data("lisp/ui/icons/Numix", "lisp/ui/icons/Numix"),

    # Compiled Qt translations
